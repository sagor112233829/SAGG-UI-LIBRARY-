function UILib:CreateTab(name, layoutOrder)
	if not GUI then BuildGUI() end
	return CreateTabElement(name, layoutOrder or 0)
end

function UILib:Open()
	if not MainFrame or not OpenBtn then return end
	if MainFrame.Visible then return end
	OpenBtn.Visible = false
	MainFrame.Visible = true
	MainFrame.Size = UDim2.new(0,0,0,0)
	TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0,460,0,320)
	}):Play()
end

function UILib:Close()
	if not MainFrame or not OpenBtn then return end
	if not MainFrame.Visible then return end
	local t = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0,0,0,0),
		Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset + 230,
							MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset + 160)
	})
	t:Play()
	t.Completed:Connect(function()
		MainFrame.Visible = false
		MainFrame.Size = UDim2.new(0,460,0,320)
		MainFrame.Position = UDim2.new(0.5,-230,0.5,-160)
		OpenBtn.Visible = true
		OpenBtn.Size = UDim2.new(0,0,0,0)
		TweenService:Create(OpenBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.new(0,120,0,40)
		}):Play()
	end)
end

function UILib:Toggle()
	if not MainFrame or not OpenBtn then return end
	if MainFrame.Visible then self:Close() else self:Open() end
end

function UILib:Destroy()
	if GUI then
		GUI:Destroy()
		GUI = nil
		MainFrame = nil
		OpenBtn = nil
		Sidebar = nil
		Content = nil
		TabButtons = {}
		TabPages = {}
		CurrentTab = nil
		accentElements = {}
		schemeElements = {}
		allDropdowns = {}
	end
end

function UILib:SetAccentTheme(themeName)
	if ACCENT_THEMES[themeName] then
		config.accentTheme = themeName
		ApplyThemes()
		RefreshAllUI()
		print("[SAGG] Accent theme changed to: " .. themeName)
	else
		warn("[SAGG] Unknown accent theme: " .. tostring(themeName))
	end
end

function UILib:SetColourScheme(schemeName)
	if COLOUR_SCHEMES[schemeName] then
		config.colorScheme = schemeName
		ApplyThemes()
		RefreshAllUI()
		print("[SAGG] Colour scheme changed to: " .. schemeName)
	else
		warn("[SAGG] Unknown colour scheme: " .. tostring(schemeName))
	end
end

function UILib:SetScale(scale)
	config.scale = math.clamp(scale, 0.6, 1.2)
	UpdateScale()
	print("[SAGG] Scale set to: " .. config.scale)
end

function UILib:SetLoadingDuration(seconds)
	config.loadingDuration = math.clamp(seconds, 1, 5)
	print("[SAGG] Loading duration set to: " .. config.loadingDuration .. "s")
end

function UILib:SaveConfig()
	_G.SAGGConfig = config
	print("[SAGG] Config saved.")
end

function UILib:ResetConfig()
	config.accentTheme = DEFAULT_CONFIG.accentTheme
	config.colorScheme = DEFAULT_CONFIG.colorScheme
	config.scale = DEFAULT_CONFIG.scale
	ApplyThemes()
	RefreshAllUI()
	UpdateScale()
	print("[SAGG] Config reset to defaults.")
end

function UILib:Notify(opts)
	opts = opts or {}
	print(string.format("[SAGG] Notification: %s - %s", opts.Title or "", opts.Content or ""))
end

-- ============================
--  RAYFIELD‑STYLE COMPATIBILITY (EXACT MATCH)
-- ============================
function UILib:CreateWindow(opts)
	opts = opts or {}
	local windowName = opts.Name or "SAGG Window"
	local window = {}
	
	function window:CreateTab(tabOpts)
		tabOpts = tabOpts or {}
		local tabName = tabOpts.Name or "Tab"
		local tabObj = UILib:CreateTab(tabName, #TabButtons)
		
		local rayfieldTab = {}
		
		function rayfieldTab:CreateSection(sectionName)
			sectionName = sectionName or "Section"
			tabObj:Label(sectionName)
			
			local section = {}
			
			-- Button (Rayfield style)
			function section:CreateButton(opts)
				opts = opts or {}
				return tabObj:Button(opts.Name or "Button", opts.Callback or function() end)
			end
			
			-- Toggle (Rayfield style)
			function section:CreateToggle(opts)
				opts = opts or {}
				return tabObj:Toggle(opts.Name or "Toggle", opts.CurrentValue or false, opts.Callback or function() end)
			end
			
			-- Slider (Rayfield style)
			function section:CreateSlider(opts)
				opts = opts or {}
				local range = opts.Range or {0, 100}
				return tabObj:Slider(opts.Name or "Slider", range[1], range[2], opts.CurrentValue or range[1], opts.Callback or function() end)
			end
			
			-- Dropdown (Rayfield style)
			function section:CreateDropdown(opts)
				opts = opts or {}
				return tabObj:Dropdown(opts.Name or "Dropdown", opts.Options or {}, opts.CurrentOption or (opts.Options and opts.Options[1]) or "Option", opts.Callback or function() end)
			end
			
			-- Label (Rayfield style)
			function section:CreateLabel(text)
				return tabObj:Label(text)
			end
			
			-- Paragraph (Rayfield style)
			function section:CreateParagraph(opts)
				opts = opts or {}
				tabObj:Label(opts.Title or "Paragraph")
				tabObj:Label(opts.Content or "")
				return {}
			end
			
			return section
		end
		
		function rayfieldTab:CreateDivider()
			tabObj:Label("──────────")
			return {}
		end
		
		return rayfieldTab
	end
	
	function window:Destroy()
		UILib:Destroy()
	end
	
	return window
end

