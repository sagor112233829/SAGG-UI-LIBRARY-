	local scheme = COLOUR_SCHEMES[config.colorScheme] or COLOUR_SCHEMES.Light
	if config.colorScheme == "Dark" then
		THEME.AccentDark = Color3.fromRGB(
			math.min(255, acc.AccentDark.R * 1.5),
			math.min(255, acc.AccentDark.G * 1.5),
			math.min(255, acc.AccentDark.B * 1.5)
		)
	else
		THEME.AccentDark = acc.AccentDark
	end
	for k, v in pairs(scheme) do
		THEME[k] = v
	end
end
