local function CreateTabElement(name, layoutOrder)
	layoutOrder = layoutOrder or 0
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,0,0,38)
	btn.BackgroundColor3 = THEME.Sidebar
	btn.Text = name
	btn.Font = Enum.Font.GothamMedium
	btn.TextSize = 13
	btn.TextColor3 = THEME.SubText
	btn.AutoButtonColor = false
	btn.Parent = Sidebar
	btn.LayoutOrder = layoutOrder
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)
	table.insert(schemeElements, btn)
	btn:SetAttribute("ColorType", "Sidebar")

	local page = Instance.new("Frame")
	page.Size = UDim2.new(1,0,0,0)
	page.AutomaticSize = Enum.AutomaticSize.Y
	page.BackgroundTransparency = 1
	page.Visible = false
	page.Parent = Content
	local pageList = Instance.new("UIListLayout")
	pageList.Padding = UDim.new(0,8)
	pageList.SortOrder = Enum.SortOrder.LayoutOrder
	pageList.Parent = page

	TabButtons[name] = btn
	TabPages[name] = page

	local function select()
		for n, b in pairs(TabButtons) do
			local active = (n == name)
			TweenService:Create(b, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
				BackgroundColor3 = active and THEME.Accent or THEME.Sidebar,
				TextColor3 = active and Color3.fromRGB(255,255,255) or THEME.SubText
			}):Play()
			TabPages[n].Visible = active
		end
		CurrentTab = name
	end
	btn.MouseButton1Click:Connect(select)
	if not CurrentTab then select() end

	table.insert(accentElements, btn)
	btn:SetAttribute("ColorType", "Accent")

	local tabAPI = {}

	function tabAPI:Button(text, callback)
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,0,0,42)
		b.BackgroundColor3 = THEME.Card
		b.Text = text
		b.Font = Enum.Font.GothamMedium
		b.TextSize = 13
		b.TextColor3 = THEME.Text
		b.AutoButtonColor = false
		b.Parent = page
		Instance.new("UICorner", b).CornerRadius = UDim.new(0,10)
		local stroke = Instance.new("UIStroke")
		stroke.Color = THEME.Accent
		stroke.Transparency = 0.7
		stroke.Thickness = 1
		stroke.Parent = b
		stroke:SetAttribute("ColorType", "Accent")
		table.insert(accentElements, stroke)
		table.insert(schemeElements, b)
		b:SetAttribute("ColorType", "Card")
		b.MouseEnter:Connect(function()
			TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = THEME.CardHover}):Play()
		end)
		b.MouseLeave:Connect(function()
			TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3 = THEME.Card}):Play()
		end)
		b.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				TweenService:Create(b, TweenInfo.new(0.1), {Size = UDim2.new(1,-4,0,38)}):Play()
			end
		end)
		b.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				TweenService:Create(b, TweenInfo.new(0.1), {Size = UDim2.new(1,0,0,42)}):Play()
			end
		end)
		b.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)
		return b
	end

	function tabAPI:Toggle(text, default, callback)
		local state = default or false
		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1,0,0,44)
		frame.BackgroundColor3 = THEME.Card
		frame.Parent = page
		Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)
		table.insert(schemeElements, frame)
		frame:SetAttribute("ColorType", "Card")

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,-64,1,0)
		label.Position = UDim2.new(0,14,0,0)
		label.BackgroundTransparency = 1
		label.Text = text
		label.Font = Enum.Font.GothamMedium
		label.TextSize = 13
		label.TextColor3 = THEME.Text
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = frame
		table.insert(schemeElements, label)
		label:SetAttribute("ColorType", "Text")

		local switch = Instance.new("Frame")
		switch.Size = UDim2.new(0,46,0,24)
		switch.Position = UDim2.new(1,-58,0.5,-12)
		switch.BackgroundColor3 = state and THEME.Accent or Color3.fromRGB(225,220,235)
		switch.Parent = frame
		Instance.new("UICorner", switch).CornerRadius = UDim.new(1,0)
		table.insert(accentElements, switch)
		switch:SetAttribute("ColorType", "Accent")

		local knob = Instance.new("Frame")
		knob.Size = UDim2.new(0,18,0,18)
		knob.Position = state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)
		knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
		knob.Parent = switch
		Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

		local click = Instance.new("TextButton")
		click.Size = UDim2.new(1,0,1,0)
		click.BackgroundTransparency = 1
		click.Text = ""
		click.Parent = frame

		click.MouseButton1Click:Connect(function()
			state = not state
			TweenService:Create(switch, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
				BackgroundColor3 = state and THEME.Accent or Color3.fromRGB(225,220,235)
			}):Play()
			TweenService:Create(knob, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
				Position = state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)
			}):Play()
			if callback then callback(state) end
		end)
		return frame
	end

	function tabAPI:Slider(text, min, max, default, callback)
		local value = default or min
		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1,0,0,56)
		frame.BackgroundColor3 = THEME.Card
		frame.Parent = page
		Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)
		table.insert(schemeElements, frame)
		frame:SetAttribute("ColorType", "Card")

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,-20,0,20)
		label.Position = UDim2.new(0,14,0,8)
		label.BackgroundTransparency = 1
		label.Text = text .. "   " .. tostring(value)
		label.Font = Enum.Font.GothamMedium
		label.TextSize = 13
		label.TextColor3 = THEME.Text
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = frame
		table.insert(schemeElements, label)
		label:SetAttribute("ColorType", "Text")

		local bar = Instance.new("Frame")
		bar.Size = UDim2.new(1,-28,0,8)
		bar.Position = UDim2.new(0,14,0,36)
		bar.BackgroundColor3 = Color3.fromRGB(225,220,235)
		bar.Parent = frame
		Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)

		local fill = Instance.new("Frame")
		fill.Size = UDim2.new((value-min)/(max-min),0,1,0)
		fill.BackgroundColor3 = THEME.Accent
		fill.Parent = bar
		Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
		table.insert(accentElements, fill)
		fill:SetAttribute("ColorType", "Accent")

		local drag = Instance.new("TextButton")
		drag.Size = UDim2.new(1,0,1,24)
		drag.Position = UDim2.new(0,0,0,-8)
		drag.BackgroundTransparency = 1
		drag.Text = ""
		drag.Parent = bar

		local sliding = false
		local connection
		local function update(input)
			local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
			value = math.floor(min + (max-min) * rel)
			TweenService:Create(fill, TweenInfo.new(0.05), {Size = UDim2.new(rel,0,1,0)}):Play()
			label.Text = text .. "   " .. tostring(value)
			if callback then callback(value) end
		end
		drag.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = true
				update(input)
				connection = UIS.InputChanged:Connect(function(change)
					if change.UserInputType == Enum.UserInputType.MouseMovement or change.UserInputType == Enum.UserInputType.Touch then
						update(change)
					end
				end)
			end
		end)
		drag.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = false
				if connection then
					connection:Disconnect()
					connection = nil
				end
			end
		end)
		return frame
	end

