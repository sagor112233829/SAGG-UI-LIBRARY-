		l.BackgroundTransparency = 1
		l.Text = text
		l.Font = Enum.Font.GothamBold
		l.TextSize = 12
		l.TextColor3 = THEME.SubText
		l.TextXAlignment = Enum.TextXAlignment.Left
		l.Parent = page
		table.insert(schemeElements, l)
		l:SetAttribute("ColorType", "SubText")
		return l
	end

	function tabAPI:Dropdown(text, options, default, callback)
		local selected = default or options[1]
		local open = false
		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1,0,0,44)
		frame.BackgroundColor3 = THEME.Card
		frame.ClipsDescendants = true
		frame.ZIndex = 2
		frame.Parent = page
		Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)
		table.insert(schemeElements, frame)
		frame:SetAttribute("ColorType", "Card")
		frame:SetAttribute("Open", false)
		table.insert(allDropdowns, frame)

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1,-40,0,44)
		label.Position = UDim2.new(0,14,0,0)
		label.BackgroundTransparency = 1
		label.Text = text .. ": " .. selected
		label.Font = Enum.Font.GothamMedium
		label.TextSize = 13
		label.TextColor3 = THEME.Text
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.ZIndex = 3
		label.Parent = frame
		table.insert(schemeElements, label)
		label:SetAttribute("ColorType", "Text")

		local arrow = Instance.new("TextLabel")
		arrow.Name = "Arrow"
		arrow.Size = UDim2.new(0,30,0,44)
		arrow.Position = UDim2.new(1,-34,0,0)
		arrow.BackgroundTransparency = 1
		arrow.Text = "▾"
		arrow.TextColor3 = THEME.SubText
		arrow.Font = Enum.Font.GothamBold
		arrow.TextSize = 14
		arrow.ZIndex = 3
		arrow.Parent = frame
		table.insert(schemeElements, arrow)
		arrow:SetAttribute("ColorType", "SubText")

		local optionsList = Instance.new("Frame")
		optionsList.Size = UDim2.new(1,0,0,#options * 34)
		optionsList.Position = UDim2.new(0,0,0,44)
		optionsList.BackgroundTransparency = 1
		optionsList.ZIndex = 3
		optionsList.Parent = frame
		local optList = Instance.new("UIListLayout")
		optList.Padding = UDim.new(0,2)
		optList.SortOrder = Enum.SortOrder.LayoutOrder
		optList.Parent = optionsList

		for _, opt in ipairs(options) do
			local optBtn = Instance.new("TextButton")
			optBtn.Size = UDim2.new(1,0,0,34)
			optBtn.BackgroundColor3 = THEME.CardHover
			optBtn.Text = opt
			optBtn.Font = Enum.Font.Gotham
			optBtn.TextSize = 12
			optBtn.TextColor3 = THEME.Text
			optBtn.AutoButtonColor = false
			optBtn.ZIndex = 4
			optBtn.Parent = optionsList
			Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0,6)
			table.insert(schemeElements, optBtn)
			optBtn:SetAttribute("ColorType", "CardHover")
			optBtn.MouseEnter:Connect(function()
				TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.Accent, TextColor3 = Color3.fromRGB(255,255,255)}):Play()
			end)
			optBtn.MouseLeave:Connect(function()
				TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.CardHover, TextColor3 = THEME.Text}):Play()
			end)
			optBtn.MouseButton1Click:Connect(function()
				selected = opt
				label.Text = text .. ": " .. selected
				open = false
				frame:SetAttribute("Open", false)
				arrow.Rotation = 0
				TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1,0,0,44)}):Play()
				task.delay(0.2, function()
					if not frame:GetAttribute("Open") then frame.ZIndex = 2 end
				end)
				if callback then callback(opt) end
			end)
			table.insert(accentElements, optBtn)
			optBtn:SetAttribute("ColorType", "Accent")
		end

		local click = Instance.new("TextButton")
		click.Size = UDim2.new(1,0,0,44)
		click.BackgroundTransparency = 1
		click.Text = ""
		click.ZIndex = 5
		click.Parent = frame
		click.MouseButton1Click:Connect(function()
			open = not open
			frame:SetAttribute("Open", open)
			if open then
				CloseAllDropdowns(frame)
				frame.ZIndex = 15
				arrow.Rotation = 180
			else
				arrow.Rotation = 0
				task.delay(0.2, function()
					if not frame:GetAttribute("Open") then frame.ZIndex = 2 end
				end)
			end
			local target = open and UDim2.new(1,0,0,44 + #options * 34) or UDim2.new(1,0,0,44)
			TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = target}):Play()
		end)
		return frame
	end

	return tabAPI
end

