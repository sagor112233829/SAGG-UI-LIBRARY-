local function GetViewportSize()
	local cam = workspace.CurrentCamera
	return cam and cam.ViewportSize or Vector2.new(800,600)
end

local function MakeDraggable(uiElement, dragHandle)
	local dragging = false
	local dragStart, startPos
	local connection
	dragHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = uiElement.Position
			if connection then connection:Disconnect() end
			connection = UIS.InputChanged:Connect(function(change)
				if dragging and (change.UserInputType == Enum.UserInputType.MouseMovement or change.UserInputType == Enum.UserInputType.Touch) then
					local delta = change.Position - dragStart
					local scale = uiElement:FindFirstChildOfClass("UIScale") and uiElement:FindFirstChildOfClass("UIScale").Scale or 1
					local newX = startPos.X.Offset + (delta.X/scale)
					local newY = startPos.Y.Offset + (delta.Y/scale)
					local vp = GetViewportSize()
					local maxX = (vp.X/scale) - uiElement.AbsoluteSize.X
					local maxY = (vp.Y/scale) - uiElement.AbsoluteSize.Y
					if startPos.X.Scale > 0 then newX = newX + (vp.X * startPos.X.Scale) end
					if startPos.Y.Scale > 0 then newY = newY + (vp.Y * startPos.Y.Scale) end
					newX = math.clamp(newX, 0, math.max(0, maxX))
					newY = math.clamp(newY, 0, math.max(0, maxY))
					uiElement.Position = UDim2.new(0, newX, 0, newY)
				end
			end)
		end
	end)
	dragHandle.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			if connection then
				connection:Disconnect()
				connection = nil
			end
		end
	end)
end

local function UpdateScale()
	local vp = GetViewportSize()
	if not MainFrame or not OpenBtn then return end
	local mainScale = MainFrame:FindFirstChildOfClass("UIScale")
	local openScale = OpenBtn:FindFirstChildOfClass("UIScale")
	local s = config.scale
	if vp.X < 600 then
		s = math.clamp(s * vp.X/550, 0.4, 1.2)
	end
	if mainScale then mainScale.Scale = s end
	if openScale then openScale.Scale = s end
end

local function CloseAllDropdowns(skip)
	for _, frame in ipairs(allDropdowns) do
		if frame ~= skip and frame:GetAttribute("Open") == true then
			frame:SetAttribute("Open", false)
			local arrow = frame:FindFirstChild("Arrow")
			if arrow then arrow.Rotation = 0 end
			TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
				Size = UDim2.new(1,0,0,44)
			}):Play()
			task.delay(0.2, function()
				if not frame:GetAttribute("Open") then frame.ZIndex = 2 end
			end)
		end
	end
end

local function RefreshAllUI()
	for _, el in ipairs(accentElements) do
		if el and el.Parent then
			local colorType = el:GetAttribute("ColorType")
			if colorType == "Accent" then
				if el:IsA("TextButton") or el:IsA("Frame") then
					el.BackgroundColor3 = THEME.Accent
				elseif el:IsA("UIStroke") then
					el.Color = THEME.Accent
				end
			elseif colorType == "AccentDark" then
				if el:IsA("TextButton") or el:IsA("Frame") then
					el.BackgroundColor3 = THEME.AccentDark
				elseif el:IsA("UIStroke") then
					el.Color = THEME.AccentDark
				elseif el:IsA("TextLabel") then
					el.TextColor3 = THEME.AccentDark
				end
			end
		end
	end

	for _, el in ipairs(schemeElements) do
		if el and el.Parent then
			local colorType = el:GetAttribute("ColorType")
			if colorType and THEME[colorType] then
				if el:IsA("TextLabel") or el:IsA("TextButton") then
					el.TextColor3 = THEME[colorType]
				else
					el.BackgroundColor3 = THEME[colorType]
				end
			end
		end
	end

	for _, frame in ipairs(allDropdowns) do
		if frame and frame.Parent then
			local label = frame:FindFirstChildOfClass("TextLabel")
			if label then label.TextColor3 = THEME.Text end
			local arrow = frame:FindFirstChild("Arrow")
			if arrow then arrow.TextColor3 = THEME.SubText end
			local optionsList = frame:FindFirstChildOfClass("Frame")
			if optionsList then
				for _, btn in ipairs(optionsList:GetChildren()) do
					if btn:IsA("TextButton") then
						btn.TextColor3 = THEME.Text
						btn.BackgroundColor3 = THEME.CardHover
					end
				end
			end
		end
	end

	if MainFrame then
		MainFrame.BackgroundColor3 = THEME.Background
		local stroke = MainFrame:FindFirstChildOfClass("UIStroke")
		if stroke then stroke.Color = THEME.Accent end
	end
	if Sidebar then Sidebar.BackgroundColor3 = THEME.Sidebar end
	if OpenBtn then
		OpenBtn.BackgroundColor3 = THEME.Accent
		local stroke = OpenBtn:FindFirstChildOfClass("UIStroke")
		if stroke then stroke.Color = THEME.AccentDark end
	end
	for _, btn in pairs(TabButtons) do
		if btn.BackgroundColor3 == THEME.Accent then
			btn.BackgroundColor3 = THEME.Accent
			btn.TextColor3 = Color3.fromRGB(255,255,255)
		else
			btn.BackgroundColor3 = THEME.Sidebar
			btn.TextColor3 = THEME.SubText
		end
	end
	if Content then Content.ScrollBarImageColor3 = THEME.Accent end
end

